{
  "name": "@castaminofen/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate": "node -e \"console.log('No code generation required')\"",
    "dev": "next dev -p 3100",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "start": "next start -p 3100",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --ignore-pattern '.next/**' --ignore-pattern 'node_modules/**'",
    "test": "node -e \"console.log('No test suite configured')\"",
    "clean": "node -e \"const {rmSync}=require('fs');['.next','dist'].forEach((p)=>rmSync(p,{recursive:true,force:true}))\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\" \"scripts/**/*.mjs\"",
    "a11y:run": "node scripts/a11y-check.mjs",
    "a11y": "start-server-and-test start http://localhost:3100 a11y:run"
  },
  "dependencies": {
    "@castaminofen/shared": "workspace:*",
    "@castaminofen/ui-tokens": "workspace:*",
    "next": "^15.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.10.2",
    "@next/eslint-plugin-next": "^16.2.10",
    "@types/node": "^22.10.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.3",
    "start-server-and-test": "^2.0.11",
    "typescript": "^5.7.2"
  }
}

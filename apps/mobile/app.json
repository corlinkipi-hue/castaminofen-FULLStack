{
  "expo": {
    "name": "کستامینوفن",
    "slug": "castaminofen",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "castaminofen",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ir.castaminofen.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0f"
      },
      "package": "ir.castaminofen.app"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "web": {
      "bundler": "metro",
      "output": "static"
    }
  }
}

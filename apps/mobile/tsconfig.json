{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@castaminofen/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@castaminofen/ui-tokens": [
        "../../packages/ui-tokens/src/index.ts"
      ]
    }
  },
  "include": [

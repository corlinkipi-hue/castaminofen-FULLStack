{
  "name": "@castaminofen/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "generate": "node -e \"console.log('No code generation required')\"",
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "expo export --platform web --output-dir dist/web",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm exec eslint .",
    "test": "node -e \"console.log('No test suite configured')\"",
    "clean": "node -e \"const {rmSync}=require('fs');['.expo','dist'].forEach((p)=>rmSync(p,{recursive:true,force:true}))\"",
    "format": "prettier --write \"app/**/*.{ts,tsx,js,jsx,json,md}\" \"components/**/*.{ts,tsx,js,jsx,json,md}\" \"*.{ts,tsx,js,jsx,json,md}\""
  },
  "dependencies": {
    "@babel/runtime": "^8.0.0",
    "@castaminofen/shared": "workspace:*",
    "@castaminofen/ui-tokens": "workspace:*",
    "@expo-google-fonts/vazirmatn": "^0.2.3",
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "^14.0.4",
    "expo": "~52.0.46",
    "expo-av": "~15.0.2",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.20",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/node": "^22.10.2",
    "@types/react": "~18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~8.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.7.2"
  }
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  PODCAST
  AUDIOBOOK
  VIDEO
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  CREATOR
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

enum DownloadStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  displayName  String
  avatarUrl    String?
  role         String   @default("USER")
  locale       String?  @default("fa")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creatorProfile CreatorProfile?
  subscription    Subscription?
  purchases       Purchase[]
  refreshTokens   RefreshToken[]
  follows         Follow[]
  libraryItems    LibraryItem[]
  playlists       Playlist[]
  playbackStates  PlaybackState[]
  downloads       Download[]

  @@map("users")
}

model CreatorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  slug        String   @unique
  bio         String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  contents    Content[]
  follows     Follow[]

  @@map("creator_profiles")
}

model Content {
  id            String        @id @default(cuid())
  creatorId     String
  type          ContentType
  title         String
  slug          String        @unique
  description   String?
  coverUrl      String?
  isPremium     Boolean       @default(false)
  price         Int?
  status        ContentStatus @default(DRAFT)
  episodeCount  Int           @default(0)
  totalDuration Int           @default(0)
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  creator       CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  episodes      Episode[]
  libraryItems  LibraryItem[]
  tags          ContentTag[]

  @@map("contents")
}

model Episode {
  id            String   @id @default(cuid())
  contentId     String
  title         String
  slug          String   @unique
  description   String?
  duration      Int      @default(0)
  episodeNumber Int
  mediaUrl      String?
  mediaKey      String?
  isVideo       Boolean  @default(false)
  isPremium     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  content         Content           @relation(fields: [contentId], references: [id], onDelete: Cascade)
  playbackStates  PlaybackState[]
  downloads       Download[]
  playlistItems   PlaylistItem[]

  @@map("episodes")
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  contents  ContentTag[]

  @@map("tags")
}

model ContentTag {
  contentId String
  tagId     String

  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
  @@map("content_tags")
}

model Subscription {
  id         String               @id @default(cuid())
  userId     String               @unique
  plan       SubscriptionPlan     @default(FREE)
  status     SubscriptionStatus   @default(ACTIVE)
  expiresAt  DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Purchase {
  id           String    @id @default(cuid())
  userId       String
  contentId    String?
  gateway      String
  gatewayName  String?
  gatewayRef   String    @unique
  amount       Int
  status       String    @default("PENDING")
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("purchases")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Follow {
  id         String   @id @default(cuid())
  userId     String
  creatorId  String
  createdAt  DateTime @default(now())

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator    CreatorProfile  @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([userId, creatorId])
  @@map("follows")
}

model LibraryItem {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  addedAt   DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@map("library_items")
}

model Playlist {
  id          String        @id @default(cuid())
  userId      String
  title       String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       PlaylistItem[]

  @@map("playlists")
}

model PlaylistItem {
  id          String   @id @default(cuid())
  playlistId  String
  episodeId   String
  position    Int
  createdAt   DateTime @default(now())

  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  episode     Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([playlistId, episodeId])
  @@map("playlist_items")
}

model PlaybackState {
  id            String   @id @default(cuid())
  userId        String
  episodeId     String
  position      Int      @default(0)
  duration      Int      @default(0)
  playbackSpeed Float    @default(1)
  isCompleted   Boolean  @default(false)
  deviceId      String?
  lastPlayedAt  DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode       Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@map("playback_states")
}

model Download {
  id           String         @id @default(cuid())
  userId       String
  episodeId    String
  status       DownloadStatus @default(PENDING)
  quality      String?        @default("medium")
  fileSize     Int            @default(0)
  localPath    String?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode      Episode        @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@map("downloads")
}

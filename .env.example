# Database
DATABASE_URL=postgresql://castaminofen:castaminofen@127.0.0.1:5432/castaminofen

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# OAuth (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Object Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=castaminofen-media
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/castaminofen-media

# CDN / Signed URLs
MEDIA_SIGNING_SECRET=change-me-media-signing-secret
MEDIA_URL_EXPIRY_SECONDS=3600

# Service Ports
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
CONTENT_SERVICE_PORT=3002
MEDIA_SERVICE_PORT=3003
USER_SERVICE_PORT=3004

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# Mobile: localhost only works on emulator/simulator. On a physical device Expo auto-uses your PC LAN IP.
# Override manually if needed: EXPO_PUBLIC_API_URL=http://192.168.1.10:3000/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Payment (Iranian gateway stub)
PAYMENT_GATEWAY=zarinpal
ZARINPAL_MERCHANT_ID=
